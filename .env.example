# XAU/USD Trading Signal Engine Configuration
# Copy this to .env and fill in your actual values

# Anthropic API key for Claude Critic Layer
ANTHROPIC_API_KEY=sk-ant-...

# Data source API keys (choose one or use MetaTrader5)
TWELVEDATA_API_KEY=...

# Optional: Override data directory (default: ./data)
DATA_DIR=./data

# Optional: Flask debug mode (set to False in production)
FLASK_DEBUG=False
